## get rid of command not found ##
alias zshconfig="zed ~/.zshrc"

## Apparenlty I need to copy this more often than I thought.
alias sshcopy="pbcopy < ~/.ssh/id_rsa.pub"

## Docker
alias dockerls="docker ps --format \"table {{.Names}}\t{{.State}}\t{{.Image}}\""

# Directories
setopt auto_cd
alias -g ...='../..'
alias -g ....='../../..'
alias -g .....='../../../..'
alias -g ......='../../../../..'

alias -- -='cd -'
alias 1='cd -1'
alias 2='cd -2'
alias 3='cd -3'
alias 4='cd -4'
alias 5='cd -5'
alias 6='cd -6'
alias 7='cd -7'
alias 8='cd -8'
alias 9='cd -9'

alias md='mkdir -p'
alias rd=rmdir

alias lsa='ls -lah'
alias l='ls -lah --color=auto'
alias ll='ls -lh'
alias la='ls -lAh'
