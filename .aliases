## get rid of command not found ##
alias zshconfig="zed ~/.zshrc"

## Docker
alias dockerls="docker ps --format \"table {{.Names}}\t{{.State}}\t{{.Image}}\""

# Directories
setopt auto_cd
alias -g ...='../..'
alias -g ....='../../..'
alias -g .....='../../../..'
alias -g ......='../../../../..'

alias -- -='cd -'

alias md='mkdir -p'
alias rd=rmdir

alias l='eza -lah --git --time-style relative'
